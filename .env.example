# auto: App Serverを試し、失敗時はモックへフォールバック
# mock: 常に決定論的モックを利用
# app-server: App Serverを優先（最終的な安全フォールバックは有効）
AGENT_MODE=auto
CODEX_BIN=codex
PORT=3001
# 未設定時はautoで15000ms、app-serverで60000ms。必要な場合だけ上書きします。
# APP_SERVER_TIMEOUT_MS=60000
GAME_STATE_FILE=./apps/server/data/game-state.json

# 公開Worker/ローカルAPIから、別プロセスのAgent Worker経由でApp Serverを使う場合
# URL未設定・停止・タイムアウト時は既存の決定論的モックへ自動フォールバックします。
# AGENT_WORKER_URL=http://127.0.0.1:3002
# AGENT_WORKER_TOKEN=replace-with-a-long-random-secret
# AGENT_WORKER_TIMEOUT_MS=60000
# AGENT_WORKER_PROBE_TIMEOUT_MS=2000

# 公開WorkerはAgent Workerを利用できないときだけOpenAI Responses APIを試します。
# OPENAI_API_KEYは必ずSitesのSecretとして登録し、この追跡対象ファイルへ実値を書かないでください。
# OPENAI_API_KEY=
# OPENAI_API_MODEL=gpt-5.6-terra
# OPENAI_API_TIMEOUT_MS=30000

# Agent Workerゲートウェイ自体の待受設定（本番ではtoken必須）
# AGENT_WORKER_HOST=127.0.0.1
# AGENT_WORKER_PORT=3002
# AGENT_WORKER_MAX_CONCURRENT_INVOCATIONS=8
# AGENT_WORKER_MAX_INVOCATIONS_PER_MINUTE=60
# AGENT_WORKER_REQUEST_TIMEOUT_MS=180000
# AGENT_WORKER_SHUTDOWN_TIMEOUT_MS=10000
# AGENT_WORKER_IDEMPOTENCY_TTL_MS=300000
# AGENT_WORKER_IDEMPOTENCY_MAX_ENTRIES=256
# AGENT_WORKER_APP_SERVER_REQUEST_TIMEOUT_MS=30000
# AGENT_WORKER_APP_SERVER_TURN_TIMEOUT_MS=50000
# Agent Worker内だけに適用し、普段のCodex設定は変更しません。
# デコピン/Haru/AoiにはFAST、Director/振り返りにはDELIBERATEを使います。
# AGENT_WORKER_MODEL=gpt-5.6-terra
# AGENT_WORKER_FAST_REASONING_EFFORT=low
# AGENT_WORKER_DELIBERATE_REASONING_EFFORT=medium
# 旧名 APP_SERVER_REQUEST_TIMEOUT_MS / APP_SERVER_TURN_TIMEOUT_MS も互換目的で利用できます。

# App Serverは既定で空の一時ディレクトリから起動します。
# カスタムCWDが必要な場合だけ指定し、本番では明示的な許可も必要です。
# AGENT_WORKER_CWD=/path/to/empty/runtime-directory
# AGENT_WORKER_ALLOW_CUSTOM_CWD=false
