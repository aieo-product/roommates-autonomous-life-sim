      "portrait": "mizuhara-aoi/portraits/ui-bust-v2.png",
      "sheet": "mizuhara-aoi/walk-cycle.png"
    },
    {
      "id": "navigator",
      "name": "デコピン",
      "role": "player-command-agent",
      "animationPreset": "hover",
