{
  "$schema": "../../schemas/roommates-asset-format-v1.schema.json",
  "format": "roommates.room-pack",
  "formatVersion": 1,
  "id": "roommates.sample-room",
  "name": "ROOMMATES v1 sample room",
  "packVersion": "1.0.0",
  "license": {
    "spdx": "CC-BY-4.0",
    "attribution": "ROOMMATES contributors",
    "source": "https://github.com/aieo-product/teamOtaniHackathon"
  },
  "grid": {
    "type": "square",
    "columns": 12,
    "rows": 10,
    "tileSize": 1
  },
  "projection": {
    "type": "isometric-cutaway",
    "tileWidthPx": 50,
    "tileHeightPx": 25,
    "origin": { "x": 300, "y": 50 },
    "cameraDirection": "south-west-to-north-east"
  },
  "dependencies": {
    "assetPacks": [{ "id": "roommates.sample-furniture", "version": "^1.0.0" }],
    "characterPacks": [{ "id": "roommates.sample-characters", "version": "^1.0.0" }]
  },
  "rooms": [
    { "id": "entry", "name": "玄関", "bounds": { "x": 0, "y": 0, "width": 4, "height": 3 } },
    { "id": "kitchen", "name": "キッチン", "bounds": { "x": 4, "y": 0, "width": 4, "height": 4 } },
    { "id": "bathroom", "name": "浴室", "bounds": { "x": 8, "y": 0, "width": 4, "height": 4 } },
    { "id": "living", "name": "リビング", "bounds": { "x": 0, "y": 4, "width": 8, "height": 4 } },
    { "id": "balcony", "name": "バルコニー", "bounds": { "x": 8, "y": 4, "width": 4, "height": 4 } },
    { "id": "male_room", "name": "男性の個室", "bounds": { "x": 0, "y": 8, "width": 6, "height": 2 } },
    { "id": "female_room", "name": "女性の個室", "bounds": { "x": 6, "y": 8, "width": 6, "height": 2 } }
  ],
  "placements": {
    "assets": [
      { "instanceId": "entry-rug", "assetId": "sample.entry-rug", "roomId": "entry", "floorContact": { "x": 3, "y": 2 } },
      { "instanceId": "island", "assetId": "sample.island-kitchen", "roomId": "kitchen", "floorContact": { "x": 6, "y": 3 } },
      { "instanceId": "fridge", "assetId": "sample.refrigerator", "roomId": "kitchen", "floorContact": { "x": 8, "y": 4 } },
      { "instanceId": "bath", "assetId": "sample.bathtub", "roomId": "bathroom", "floorContact": { "x": 11, "y": 3 } },
      { "instanceId": "sofa", "assetId": "sample.sofa", "roomId": "living", "floorContact": { "x": 4, "y": 7 } },
      { "instanceId": "rack", "assetId": "sample.drying-rack", "roomId": "balcony", "floorContact": { "x": 11, "y": 7 } }
    ],
    "characters": [
      { "instanceId": "male-character", "assetId": "sample.male", "roomId": "kitchen", "floorContact": { "x": 5, "y": 2 }, "facing": "east" },
      { "instanceId": "female-character", "assetId": "sample.female", "roomId": "kitchen", "floorContact": { "x": 7, "y": 2 }, "facing": "west" }
    ]
  },
  "extensions": {
    "roommates.room-id-aliases": {
      "haru_room": "male_room",
      "aoi_room": "female_room",
      "famale_room": "female_room"
    }
  }
}
