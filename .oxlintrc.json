{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "react", "typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "eqeqeq": "error",
    "no-console": "warn",
    "react/self-closing-comp": "warn"
  }
}
